{
  "name": "memorymerge",
  "version": "0.1.0",
  "description": "Persistent decentralized memory OS for AI agent swarms, powered by 0G Storage and 0G Compute",
  "main": "index.js",
  "exports": {
    "./skill": "./dist/skill/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/orchestrator/index.ts",
    "agent": "ts-node examples/interactiveAgent.ts",
    "inherit": "ts-node examples/crossSwarmDemo.ts",
    "openclaw": "ts-node examples/openClawAgent.ts",
    "verify": "ts-node examples/verifyFact.ts",
    "start": "ts-node src/orchestrator/index.ts",
    "continuous": "ts-node --transpile-only -e \"require('dotenv').config(); const { MemoryMergeOrchestrator } = require('./src/orchestrator/index'); new MemoryMergeOrchestrator().runContinuous(process.argv[2] ?? 'Research the current state of decentralized AI and 0G Labs in 2026');\"",
    "example": "ts-node examples/researchSwarm.ts",
    "test": "jest --testPathPatterns=tests/",
    "test:storage": "ts-node src/sdk/storageClient.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@0glabs/0g-serving-broker": "^0.7.5",
    "dotenv": "^17.4.2",
    "merkletreejs": "^0.6.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.15",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "ethers": "6.13.1",
    "hardhat": "^2.28.0",
    "hardhat-gas-reporter": "^2.3.0",
    "nodemon": "^3.1.14",
    "solidity-coverage": "^0.8.17",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "types": [
            "jest",
            "node"
          ],
          "skipLibCheck": true,
          "strict": false
        }
      }
    }
  }
}
